VITE_API_BASE=/api
VITE_BACKEND_TARGET=http://localhost:3001
VITE_CSRF_HEADER_NAME=token-csrf
VITE_CSRF_COOKIE_NAMES=cookie-csrf-1,cookie-csrf-2
VITE_CSRF_ENDPOINT=/csrf-token-endpoint

FRONTEND_PORT=sua_porta_frontend
NGROK_AUTH_TOKEN=seu_token_de_autenticacao_ngrok
NGROK_SKIP_BROWSER_WARNING=true ou false (dependendo se você quer pular o aviso do navegador ao iniciar o ngrok)

# Após iniciar o ngrok, atualize o backend/.env CORS_ALLOWED_ORIGINS com a URL fornecida pelo ngrok (ex: https://seu-tunel.ngrok-free.dev)
